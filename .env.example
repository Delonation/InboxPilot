APP_NAME=InboxPilot
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=your_database
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=database

# ---------------------------------------------------------------------------
# System / transactional mail (password reset, optional email verification,
# admin notices). This is YOUR OWN SMTP as the operator of this instance.
# It is separate from the per-user campaign SMTP accounts (stored encrypted
# in the database). On Hostinger shared hosting the simplest reliable choice
# is a mailbox on your own domain: smtp.hostinger.com on port 465 (SSL).
# Never use port 25 (blocked on shared hosting). See README for the full
# provider/port compatibility table.
# ---------------------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=465
MAIL_SCHEME=smtps
MAIL_USERNAME=system@your-domain.com
MAIL_PASSWORD=your_system_smtp_password
MAIL_FROM_ADDRESS="system@your-domain.com"
MAIL_FROM_NAME="${APP_NAME}"

# ---------------------------------------------------------------------------
# InboxPilot feature toggles
# ---------------------------------------------------------------------------
MAIL_VERIFICATION_ENABLED=false
REGISTRATION_OPEN=true

# ---------------------------------------------------------------------------
# Google reCAPTCHA v2 (checkbox). Get keys at https://www.google.com/recaptcha
# Leave both blank to disable captcha. When both are set it is enforced on
# register + login.
# ---------------------------------------------------------------------------
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# ---------------------------------------------------------------------------
# Shared-host-safe sending defaults (browser AJAX chunked sender).
# ---------------------------------------------------------------------------
SEND_CHUNK_SIZE=20
SEND_DELAY_MS=400
CSV_MAX_KB=5120

VITE_APP_NAME="${APP_NAME}"
